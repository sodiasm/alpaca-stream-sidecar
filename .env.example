# ── n8n Webhook ───────────────────────────────────────────────────────────────
# Internal URL (same Zeabur project) — preferred
N8N_WEBHOOK_URL=http://n8n.zeabur.internal:5678/webhook/alpaca-trades
# OR public URL (if internal doesn't resolve)
# N8N_WEBHOOK_URL=https://your-n8n-domain.zeabur.app/webhook/alpaca-trades

# ── Health Check Port ─────────────────────────────────────────────────────────
PORT=8080

# ── Account List (comma-separated labels) ─────────────────────────────────────
# Each label must match the prefix of the account variables below
ACCOUNTS=acc1,acc2

# ── Account 1 (Paper Trading) ─────────────────────────────────────────────────
ACC1_KEY=PKXXXXXXXXXXXXXXXXXX
ACC1_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACC1_LABEL=Main Account Paper
ACC1_IS_PAPER=true

# ── Account 2 (Live Trading) ──────────────────────────────────────────────────
ACC2_KEY=AKYYYYYYYYYYYYYYYYYY
ACC2_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
ACC2_LABEL=Live Account
ACC2_IS_PAPER=false

# ── Account 3 (Optional) ──────────────────────────────────────────────────────
# ACC3_KEY=PKZZZZZZZZZZZZZZZZZZ
# ACC3_SECRET=zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz
# ACC3_LABEL=Sub Account
# ACC3_IS_PAPER=true
# Remember to add acc3 to ACCOUNTS=acc1,acc2,acc3
